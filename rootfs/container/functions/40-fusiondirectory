        fi

        render_template /container/data/nginx/fusiondirectory/templates/orchestrator.template ${NGINX_CONFIG_PATH%/}/sites.enabled/fusiondirectory/location/orchestrator.conf \
                                                                                                                                                        NGINX_LOG_ACCESS_LOCATION \
                                                                                                                                                        NGINX_LOG_ERROR_LOCATION
