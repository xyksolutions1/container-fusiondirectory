fusiondirectory_configure_themes() {
    set -x
    for tvar in $(set -o posix; env | grep '^THEME_.*_PATH=.*$' | awk -F= '{print $1}'); do
        t_name=$(echo "${tvar}" | sed -E 's|^THEME_(.*)_PATH$|\1|' | tr '[:upper:]' '[:lower:]')
        t_path=$(eval echo "\$${tvar}")
        if [ -n "${t_name}" ] && [ -n "${t_path}" ]; then
            create_folder "${t_path}" "${NGINX_USER}":"${NGINX_GROUP}" 755
            t_html_path="${NGINX_WEBROOT%/}/html/themes/${t_name}"
            t_ihtml_path="${NGINX_WEBROOT%/}/ihtml/themes/${t_name}"
            c_html_path="${t_path}/html"
            c_ihtml_path="${t_path}/ihtml"

            if [ "${t_name}" = "breezy" ]; then
                if [ ! -d "${c_html_path}" ] && [ -d "${t_html_path}" ]; then
                    mkdir -p "${c_html_path}"
                    cp -aR "${t_html_path}/." "${c_html_path}/"
                fi
                if [ -d "${t_html_path}" ]; then
                    rm -rf "${t_html_path}"
                fi
                ln -sf "${c_html_path}" "${t_html_path}"
                if [ ! -d "${c_ihtml_path}" ] && [ -d "${t_ihtml_path}" ]; then
                    mkdir -p "${c_ihtml_path}"
                    cp -aR "${t_ihtml_path}/." "${c_ihtml_path}/"
                fi
                if [ -d "${t_ihtml_path}" ]; then
                    rm -rf "${t_ihtml_path}"
                fi
                ln -sf "${c_ihtml_path}" "${t_ihtml_path}"
                continue
            fi

            if [ -d "${t_html_path}" ]; then
                if dir_empty "${c_html_path}"; then
                    cp -aR "${t_html_path}/." "${c_html_path}/"
                fi
                rm -rf "${t_html_path}"
            fi
            ln -sf "${c_html_path}" "${t_html_path}"
            if [ -d "${t_ihtml_path}" ]; then
                mkdir -p "${c_ihtml_path}"
                if dir_empty "${c_ihtml_path}"; then
                    cp -aR "${t_ihtml_path}/." "${c_ihtml_path}/"
                fi
                rm -rf "${t_ihtml_path}"
            fi
            ln -sf "${c_ihtml_path}" "${t_ihtml_path}"
        fi
    done
    set +x
}

fusiondirectory_configure_webroot() {
    yes Yes | silent fusiondirectory-configuration-manager --set-var fd_home="${NGINX_WEBROOT}" --check-config --update-cache
    yes Yes | silent fusiondirectory-configuration-manager --set-var fd_home="${NGINX_WEBROOT}" --write-vars --check-directories --update-locales --update-cache
    silent fusiondirectory-configuration-manager --set-var fd_home="${NGINX_WEBROOT}" --write-vars
}

